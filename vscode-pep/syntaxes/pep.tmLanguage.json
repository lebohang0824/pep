{
  "scopeName": "source.pep",
  "name": "Pep",
  "fileTypes": ["pep"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#delimiters" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration",
          "match": "\\b(app|action|feature|meta|params|rules|events|function)\\b"
        },
        {
          "name": "keyword.declaration.param",
          "match": "\\bparam\\b"
        },
        {
          "name": "keyword.declaration.rule",
          "match": "\\brule\\b"
        },
        {
          "name": "keyword.control.trigger",
          "match": "\\btrigger\\b"
        },
        {
          "name": "keyword.control",
          "match": "\\b(if|empty|reject|return|not|end)\\b"
        },
        {
          "name": "storage.type",
          "match": "\\b(enum|string|integer)\\b"
        },
        {
          "name": "constant.language",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison",
          "match": "=="
        },
        {
          "name": "keyword.operator.assignment",
          "match": ":"
        }
      ]
    },
    "delimiters": {
      "patterns": [
        {
          "name": "punctuation.definition.brace.curly",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.brace.round",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.comma",
          "match": ","
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function",
          "match": "(?<=\\b(?:action|feature|function)\\s)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "entity.name.function",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        },
        {
          "name": "entity.name.type",
          "match": "(?<=\\b(?:app|param|rule)\\s)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "variable.other",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
